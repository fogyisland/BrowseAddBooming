{
  "manifest_version": 3,
  "name": "小铭助手",
  "version": "1.0.0",
  "description": "基于AI的页面分析和文本优化助手",
  "action": {
    "default_popup": "index.html",
    "default_title": "小铭助手"
  },
  "permissions": [
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "analyze-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      },
      "description": "分析当前页面"
    },
    "optimize-text": {
      "suggested_key": {
        "default": "Ctrl+Shift+J",
        "mac": "Command+Shift+J"
      },
      "description": "优化选中文本"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "webRequest",
    "clipboardRead",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ]
}
